generator client {
  provider = "prisma-client"
  output   = "../lib/prisma"
}

datasource db {
  provider = "postgresql"
}

generator pothos {
  provider     = "prisma-pothos-types"
  clientOutput = "./prisma"
  output       = "../lib/pothos-prisma-types.ts"

}

/// A list of tasks grouped under a shared name.
model TaskList {
  id            Int         @id @default(autoincrement())
  /// The display name shown to the user.
  name          String
  createdAt     DateTime    @default(now())
  task          Task[]
}

/// Specific task the user has created.
model Task {
  id            Int       @id @default(autoincrement())
  title         String
  completed     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tasklistId    Int
  tasklist      TaskList  @relation(fields: [tasklistId], references: [id])
}

